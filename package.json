{
  "name": "measurepro-desktop",
  "version": "16.1.49",
  "description": "MeasurePRO Desktop - Professional Measurement Application",
  "author": "Soltec Innovation <support@soltecinnovation.com>",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && cross-env IS_DEV=true electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "start": "electron .",
    "type-check": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-leaflet/core": "^2.1.0",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.75.0",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-virtual": "^3.13.12",
    "@tarikjabiri/dxf": "^2.8.9",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "firebase": "^11.7.1",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "lucide-react": "^0.511.0",
    "mathjs": "^15.1.1",
    "openai": "^6.33.0",
    "piexifjs": "^1.0.6",
    "proj4": "^2.20.6",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.56.4",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.14.0",
    "semver": "^7.7.4",
    "serialport": "^13.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "three": "^0.183.2",
    "wouter": "^3.7.1",
    "xmlbuilder2": "^4.0.3",
    "zod": "^3.24.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.2",
    "@types/piexifjs": "^1.0.0",
    "@types/proj4": "^2.5.6",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.183.1",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.soltecinnovation.measurepro",
    "productName": "MeasurePRO",
    "copyright": "Copyright © 2025 Soltec Innovation",
    "directories": {
      "output": "release-builds",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/.bin/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/vite/**/*",
      "!node_modules/@vitejs/**/*",
      "!node_modules/typescript/**/*",
      "!node_modules/esbuild/**/*",
      "!node_modules/@esbuild/**/*",
      "!node_modules/rollup/**/*",
      "!node_modules/@rollup/**/*",
      "!node_modules/node-gyp/**/*",
      "!node_modules/concurrently/**/*",
      "!node_modules/app-builder-lib/**/*",
      "!node_modules/app-builder-bin/**/*",
      "!node_modules/builder-util/**/*",
      "!node_modules/7zip-bin/**/*",
      "!node_modules/autoprefixer/**/*",
      "!node_modules/postcss/**/*",
      "!node_modules/tailwindcss/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "MeasurePROSetup.exe",
      "include": "build-resources/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "SolTecInnov",
      "repo": "measurepro-releases",
      "private": true
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "node_modules/@serialport/bindings-cpp/**/*",
      "node_modules/node-gyp-build/**/*"
    ],
    "artifactName": "MeasurePROSetup.exe",
    "extraResources": [
      {
        "from": "build-resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build-resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ]
  }
}
